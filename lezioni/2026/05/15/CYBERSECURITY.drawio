        <mxCell id="14" value="&lt;h1&gt;CSRF Cross-site Request Forgery&lt;/h1&gt;&lt;p&gt;&lt;font color=&quot;#007fff&quot;&gt;Aggressore induce gli utenti a eseguire azioni &lt;/font&gt;che non intendono eseguire.&lt;br&gt;Consente all&#39;aggressore di aggirare la politiche di sicurezza e far in modo che diversi siti web interagiscano tra loro.&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;align=center;" vertex="1" parent="1">
          <mxGeometry x="49" y="850" width="730" height="120" as="geometry" />
        </mxCell>
        <mxCell id="19" value="setcookie(&quot;username&quot;,&quot;pippo&quot;,[&lt;br&gt;&quot;expires&quot; =&amp;gt; time()+3600,&lt;br&gt;&quot;path&quot; =&amp;gt; &quot;/&quot;,&lt;br&gt;&quot;domain&quot; =&amp;gt; &quot;&quot;,&lt;br&gt;&quot;secure&quot; =&amp;gt; true,&lt;br&gt;&quot;httponly&quot; =&amp;gt; true,&lt;br&gt;&quot;samesite&quot; =&amp;gt; &quot;None&quot;&lt;br&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
