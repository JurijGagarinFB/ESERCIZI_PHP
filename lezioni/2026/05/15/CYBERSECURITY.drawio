        <mxCell id="1" parent="0" />
        <mxCell id="2" value="&lt;h1&gt;&lt;font style=&quot;font-size: 36px;&quot;&gt;WEB Security&lt;/font&gt;&lt;/h1&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Validazione e Sanificazione&lt;br&gt;XSS (Cross-Site-scripting)&lt;br&gt;CSRF(Cross-Site Request Forgery)&lt;br&gt;Cookie(Https, Http-only, Secure, SameSite)&lt;br&gt;SQL Injection&lt;/font&gt;&lt;/div&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;align=center;" vertex="1" parent="1">
