        <mxCell id="4" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b&gt;Validazione Sanificazione dei dati&lt;/b&gt;&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
